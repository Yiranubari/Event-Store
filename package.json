{
  "name": "event-store",
  "version": "1.0.0",
  "description": "Append-only event store with an in-memory byte-offset index",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "append-only",
    "event-store",
    "wal"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
